# Database (required) — get a free Neon database at https://neon.tech
NETLIFY_DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require

# App
NODE_ENV=development
PORT=3000

# Session & JWT (required — use any random string)
SESSION_SECRET=change-this-to-a-random-string
JWT_SECRET=change-this-to-a-random-string

# Email magic links (optional — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx
APP_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
